                      <input value={safeString(localScenes[activeSceneId]?.matchupTitle, '')} onChange={e => setLocalActiveScene({ matchupTitle: e.target.value })} className="w-full h-10 rounded-lg px-3 bg-zinc-950 border border-zinc-700 text-zinc-100" placeholder="KEY MATCHUP" />
                      <label className="text-[10px] text-zinc-500 uppercase tracking-widest font-black">Subheader</label>
                      <input value={safeString(localScenes[activeSceneId]?.vsText, '')} onChange={e => setLocalActiveScene({ vsText: e.target.value })} className="w-full h-10 rounded-lg px-3 bg-zinc-950 border border-zinc-700 text-zinc-100" placeholder="Team vs Team" />
                    </>
                  )}

                  {safeString(localScenes[activeSceneId]?.template) === 'player_stats' && (
                    <>
                      <label className="text-[10px] text-zinc-500 uppercase tracking-widest font-black">Header</label>
                      <input value={safeString(localScenes[activeSceneId]?.name, '')} onChange={e => setLocalActiveScene({ name: e.target.value })} className="w-full h-10 rounded-lg px-3 bg-zinc-950 border border-zinc-700 text-zinc-100" placeholder="Player Name" />
                      <label className="text-[10px] text-zinc-500 uppercase tracking-widest font-black">Subheader</label>
                      <input value={safeString(localScenes[activeSceneId]?.team, '')} onChange={e => setLocalActiveScene({ team: e.target.value })} className="w-full h-10 rounded-lg px-3 bg-zinc-950 border border-zinc-700 text-zinc-100" placeholder="Team" />
                    </>
                  )}

                  {selectedTemplateBindings.length > 0 && (
                    <div className="pt-3 border-t border-zinc-800 mt-2 space-y-2">
                      <div className="text-[10px] text-zinc-500 uppercase tracking-widest font-black">Bound Data Quick Overrides</div>
                      {selectedTemplateBindings.map(layer => (
                        <div key={layer.id}>
                          <label className="text-[10px] text-zinc-500 uppercase tracking-widest font-black">{safeString(layer.dataPath)}</label>
                          <input
                            value={safeString(resolvePath(localScenes[activeSceneId]?.customTemplateOverrides || {}, layer.dataPath), '')}
                            onChange={e => setLocalActiveScene(prev => ({
                              customTemplateOverrides: {
                                ...(prev.customTemplateOverrides || {}),
                                ...layer.dataPath.split('.').reverse().reduce((acc, key, idx, arr) => idx === 0 ? { [key]: e.target.value } : { [key]: acc }, {})
                              }
                            }))}
                            className="w-full h-10 rounded-lg px-3 bg-zinc-950 border border-zinc-700 text-zinc-100"
                            placeholder={`Override ${safeString(layer.dataPath)}`}
                          />
                        </div>
                      ))}
                    </div>
                  )}

                  <div className="pt-3 border-t border-zinc-800 mt-2">
                    <div className="text-[10px] text-zinc-500 uppercase tracking-widest font-black mb-2">Game State Overrides</div>
                    <div className="grid grid-cols-2 gap-2">
                      <button onClick={() => setLocalActiveScene(prev => ({ homeScore: (Number(prev.homeScore) || 0) + 1 }))} className="h-14 rounded-xl bg-zinc-800 border border-zinc-700 text-zinc-100 text-sm font-black">HOME +1</button>
                      <button onClick={() => setLocalActiveScene(prev => ({ awayScore: (Number(prev.awayScore) || 0) + 1 }))} className="h-14 rounded-xl bg-zinc-800 border border-zinc-700 text-zinc-100 text-sm font-black">AWAY +1</button>
                      <button onClick={() => setLocalActiveScene({ balls: 0, strikes: 0, outs: 0 })} className="h-14 rounded-xl bg-zinc-800 border border-zinc-700 text-zinc-100 text-sm font-black">RESET COUNT</button>
                      <button onClick={() => setLocalActiveScene({ inning: 1, inningTop: true })} className="h-14 rounded-xl bg-zinc-800 border border-zinc-700 text-zinc-100 text-sm font-black">RESET INNING</button>
                    </div>
                  </div>

                  <div className="pt-3 border-t border-zinc-800">
                    <div className="text-[10px] text-zinc-500 uppercase tracking-widest font-black mb-2">Live Data Snapshot</div>
                    <div className="rounded-lg border border-zinc-700 bg-zinc-950 p-3 font-mono text-xs text-zinc-300 space-y-1">
                      <div>HOME: {safeString(liveData?.mlb?.scoreboard?.homeName, 'HOME')} {safeString(liveData?.mlb?.scoreboard?.homeScore, 0)}</div>
                      <div>AWAY: {safeString(liveData?.mlb?.scoreboard?.awayName, 'AWAY')} {safeString(liveData?.mlb?.scoreboard?.awayScore, 0)}</div>
                      <div>INNING: {safeString(liveData?.mlb?.scoreboard?.inning, '1st')} ({safeString(liveData?.mlb?.scoreboard?.state, 'Top')})</div>
                    </div>
                  </div>
                </div>
              </section>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}