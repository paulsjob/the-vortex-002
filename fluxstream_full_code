const CustomTemplateRenderer = ({ data, globalData, assets = [] }) => {
  const tmpl = data.customTemplateData;
  if (!tmpl) return null;

  let finalBgImage = tmpl.bgImage; 
  if (tmpl.bgImageId && assets && assets.length > 0) {
     const found = assets.find(a => a.id === tmpl.bgImageId);
     if (found) finalBgImage = found.url;
  }

  return (
    <div className="absolute inset-0 flex items-center justify-center overflow-hidden pointer-events-none">
      <svg viewBox={`0 0 ${tmpl.width} ${tmpl.height}`} className="w-full h-full max-w-full max-h-full" preserveAspectRatio="xMidYMid meet">
        {tmpl.bgColor && tmpl.bgColor !== 'transparent' && (
           <rect width={tmpl.width} height={tmpl.height} fill={tmpl.bgColor} />
        )}
        {finalBgImage && <image href={finalBgImage} width={tmpl.width} height={tmpl.height} preserveAspectRatio={`xMidYMid ${tmpl.bgFit || 'slice'}`} />}
        {tmpl.layers && tmpl.layers.map(l => {
           if (l.type === 'image') {
              let finalLayerUrl = l.url;
              if (l.imageId && assets && assets.length > 0) {
                 const layerFound = assets.find(a => a.id === l.imageId);
                 if (layerFound) finalLayerUrl = layerFound.url;
              }
              if (!finalLayerUrl) return null;
              return <image key={l.id} x={l.x} y={l.y} width={l.width} height={l.height} href={finalLayerUrl} preserveAspectRatio="none" />;
           }

           // Default to Text layer rendering
           let textContent = l.text;
           if (l.dataPath) {
              const overrideVal = resolvePath(data?.customTemplateOverrides || {}, l.dataPath);
              if (overrideVal !== null && overrideVal !== undefined && safeString(overrideVal) !== '') {
                textContent = safeString(overrideVal);
              } else if (globalData) {
                const boundVal = resolvePath(globalData, l.dataPath);
                if (boundVal !== null && boundVal !== undefined) textContent = safeString(boundVal);
              }
           }
           return (
             <text 
               key={l.id} x={l.x} y={l.y} 
               fontSize={l.fontSize} fill={l.color} fontWeight={l.fontWeight} 
               textAnchor={l.textAlign === 'center' ? 'middle' : l.textAlign === 'right' ? 'end' : 'start'} 
               dominantBaseline="hanging"
               style={{ textShadow: '2px 2px 8px rgba(0,0,0,0.5)' }}
             >
                {safeString(textContent)}
             </text>
           );
        })}
      </svg>
    </div>
  );
};

