  if (!localData || typeof localData !== 'object') return null;
  if (localData.template === 'custom') return <div className="text-[10px] text-slate-500 uppercase tracking-widest font-black text-center py-10">Custom Templates are immutable. Use Design Tab to edit.</div>

  if (localData.template === 'player_stats') {
     const players = [...ROSTER_DB.batters, ...ROSTER_DB.pitchers];
     return (
       <div className="space-y-6 animate-in fade-in">
          <div className="bg-slate-900 rounded p-3 border border-slate-800 text-left">
