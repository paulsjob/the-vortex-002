const LibraryPanel = ({ 
  folders, assets, currentFolderId, setCurrentFolderId, 
  createFolderAction, deleteFolderAction, saveLibrary, 
  setFolders, setAssets, isAddingFolder, setIsAddingFolder, 
  newFolderName, setNewFolderName, onSetBackground, onAddImageLayer 
}) => {
  const currentFolder = folders.find(f => f.id === currentFolderId) || folders[0];
  const filteredAssets = assets.filter(a => a.parentId === currentFolderId);
  const subFolders = folders.filter(f => f.parentId === currentFolderId);
  const [designSearch, setDesignSearch] = useState('');
  const [designTypeFilter, setDesignTypeFilter] = useState('all');
  const [designViewMode, setDesignViewMode] = useState('grid');
  const designAssetTypeOf = (asset) => {
    const n = safeString(asset?.name).toLowerCase();
    if (n.endsWith('.png')) return 'png';
    if (n.endsWith('.jpg') || n.endsWith('.jpeg')) return 'jpg';
    return 'other';
  };
  const designVisibleAssets = filteredAssets.filter(a => {
    const searchOk = !designSearch || safeString(a.name).toLowerCase().includes(safeString(designSearch).toLowerCase());
    const type = designAssetTypeOf(a);
    const typeOk = designTypeFilter === 'all' ? true : type === designTypeFilter;
    return searchOk && typeOk;
  });

  const handleUpload = (e) => {
    const files = Array.from(e.target.files);
    if (!files.length) return;

    let processedAssets = [];
    let completedCount = 0;

    files.forEach((file) => {
      const r = new FileReader();
      r.onload = (ev) => {
        const img = new Image();
        img.onload = () => {
          const newAsset = {
            id: 'a_' + Date.now() + Math.random().toString(36).substr(2, 5),
            url: ev.target.result,
            name: file.name,
            parentId: currentFolderId,
            width: img.width,
            height: img.height,
            size: (file.size / 1024).toFixed(1) + ' KB'
          };
          processedAssets.push(newAsset);
          completedCount++;
          
          if (completedCount === files.length) {
            const updatedAssets = [...assets, ...processedAssets];
            setAssets(updatedAssets);
            saveLibrary(folders, updatedAssets);
          }
        };
        img.src = ev.target.result;
      };
      r.readAsDataURL(file);
    });
  };

  return (
    <div className="space-y-4 animate-in fade-in flex flex-col h-full">
       <div className="flex items-center text-[10px] font-black text-slate-500 mb-2 tracking-widest uppercase">
          {currentFolderId !== 'root' && (
            <button onClick={() => setCurrentFolderId(currentFolder?.parentId || 'root')} className="mr-2 hover:text-indigo-400 flex items-center bg-slate-800 px-1.5 py-0.5 rounded transition-colors"><ChevronLeft className="w-3 h-3"/> BACK</button>
          )}
          <span className="text-indigo-400">{currentFolder?.name || 'HOME'}</span>
       </div>

       <div className="mb-2 p-2 rounded-xl border border-slate-800 bg-slate-950/60">
          <div className="text-[9px] font-black text-slate-500 uppercase tracking-[0.2em] mb-2">Explorer Tree</div>
          <div className="space-y-1">
             <button onClick={() => setCurrentFolderId('root')} className={`w-full flex items-center space-x-2 px-2 py-1.5 rounded text-xs font-bold transition-colors ${currentFolderId === 'root' ? 'bg-indigo-600/20 text-indigo-400' : 'text-slate-400 hover:bg-slate-900 hover:text-white'}`}><Database className="w-3.5 h-3.5"/><span>Home</span></button>
             {folders.filter(f => f.parentId === 'root').map(f => (
               <button key={f.id} onClick={() => setCurrentFolderId(f.id)} className={`w-full flex items-center space-x-2 px-2 py-1.5 rounded text-xs font-bold transition-colors ${currentFolderId === f.id ? 'bg-indigo-600/20 text-indigo-400' : 'text-slate-400 hover:bg-slate-900 hover:text-white'}`}><Folder className="w-3.5 h-3.5"/><span className="truncate">{safeString(f.name)}</span></button>
             ))}
          </div>
