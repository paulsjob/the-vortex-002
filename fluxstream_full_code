                const p = players.find(p => p.id === e.target.value);
                if(p) update({ pName: p.name, team: p.team, pImage: p.img, stats: p.stats.season, durationLabel: '2025 SEASON' });
             }}>
                <option value="">-- Choose --</option>
                {players.map(p => <option key={p.id} value={p.id}>{p.name} ({p.team})</option>)}
             </select>
          </div>
          {localData.pName && (
             <div className="bg-slate-900 rounded p-3 border border-slate-800 animate-in slide-in-from-top duration-300 text-left">
                <label className="text-[9px] text-slate-500 block mb-1 uppercase font-black tracking-widest">Stats Duration</label>
                <select className="w-full bg-slate-900 text-white text-sm font-bold outline-none border border-slate-700 rounded p-1" onChange={(e) => {
                   const p = players.find(player => player.name === localData.pName);
                   if(p && p.stats[e.target.value]) update({ stats: p.stats[e.target.value], durationLabel: p.stats[e.target.value].label });
                }}>
                   <option value="season">Season</option>
                   <option value="career">Career</option>
                   <option value="last10">Last 10 Games</option>
                </select>
             </div>
          )}
          <InspectorInput label="Name Override" value={localData.pName} onChange={e => update({pName: e.target.value})} />
       </div>
     );
  }

  if (localData.template === 'team_stats') {
    return (
       <div className="space-y-6 animate-in fade-in text-left">
          <div className="bg-slate-900 rounded p-3 border border-slate-800">
             <label className="text-[9px] text-slate-500 block mb-1 uppercase font-black tracking-widest">Select Team</label>
             <select className="w-full bg-slate-900 text-white text-sm font-bold outline-none border border-slate-700 rounded p-1" onChange={(e) => {
                const t = TEAM_DB[e.target.value];
                if(t) update({ teamName: t.name, stats: t.splits.season, splitLabel: '2025 SEASON' });
             }}>
                <option value="">-- Choose --</option>
                <option value="NYY">Yankees</option>
                <option value="BOS">Red Sox</option>
             </select>
          </div>
          {localData.teamName && (
             <div className="bg-slate-900 rounded p-3 border border-slate-800 animate-in slide-in-from-top">
                <label className="text-[9px] text-slate-500 block mb-1 uppercase font-black tracking-widest">Split Filter</label>
                <select className="w-full bg-slate-900 text-white text-sm font-bold outline-none border border-slate-700 rounded p-1" onChange={(e) => {
                   const teamKey = safeString(localData.teamName).includes('Yankees') ? 'NYY' : 'BOS';
                   const t = TEAM_DB[teamKey];
                   if(t && t.splits[e.target.value]) update({ stats: t.splits[e.target.value], splitLabel: t.splits[e.target.value].label });
                }}>
                   <option value="season">Full Season</option>
                   <option value="june">In June</option>
                   <option value="since_apr">Since April 28</option>
                </select>
             </div>
          )}
          <InspectorInput label="Team Label Override" value={localData.teamName} onChange={e => update({teamName: e.target.value})} />
       </div>
    );
  }

  if (localData.template === 'matchup') {
    const players = matchupType === 'batters' ? ROSTER_DB.batters : ROSTER_DB.pitchers;
    const statKeys = matchupType === 'batters' ? ['AVG', 'HR', 'RBI', 'OPS'] : ['ERA', 'W', 'SO', 'WHIP'];
    return (
      <div className="space-y-6 animate-in fade-in text-left">
        <InspectorInput label="Matchup Title" value={localData.matchupTitle} onChange={e => update({matchupTitle: e.target.value})} />
        <div className="flex bg-slate-900 rounded p-1 border border-slate-800">
           <button onClick={() => setMatchupType('batters')} className={`flex-1 py-1 text-xs font-bold rounded ${matchupType === 'batters' ? 'bg-indigo-600 text-white' : 'text-slate-500 hover:text-white'}`}>BATTERS</button>
           <button onClick={() => setMatchupType('pitchers')} className={`flex-1 py-1 text-xs font-bold rounded ${matchupType === 'pitchers' ? 'bg-indigo-600 text-white' : 'text-slate-500 hover:text-white'}`}>PITCHERS</button>
        </div>
        {['p1', 'p2'].map(slot => (
           <div key={slot} className="p-4 bg-slate-900/50 rounded-xl border border-slate-800">
              <label className="text-[10px] font-bold text-indigo-500 uppercase mb-3 block tracking-widest">{slot.toUpperCase()}</label>
              <select className="w-full bg-slate-900 text-white text-sm font-bold mb-3 border border-slate-700 rounded p-1" onChange={(e) => {
                 const p = players.find(p => p.id === e.target.value);
                 if(p) update({ [`${slot}Name`]: p.name, [`${slot}Image`]: p.img });
              }}>
                 <option value="">-- Select Player --</option>
                 {players.map(p => <option key={p.id} value={p.id}>{p.name}</option>)}
              </select>
              <div className="grid grid-cols-2 gap-2">
                 {[1, 2].map(statSlot => (
                    <select key={statSlot} className="w-full bg-slate-900 text-white text-[10px] border border-slate-700 rounded p-1" onChange={(e) => {
                       const p = players.find(p => p.name === localData[`${slot}Name`]);
                       if(p && p.stats.season[e.target.value]) update({ [`${slot}Stat${statSlot}`]: p.stats.season[e.target.value], [`${slot}StatLabel${statSlot}`]: e.target.value });
                    }}>
                       <option value="">Stat</option>
                       {statKeys.map(k => <option key={k} value={k}>{k}</option>)}
                    </select>
                 ))}
              </div>
           </div>
        ))}
      </div>
    );
  }

  if (localData.template === 'image') {
    return (
       <div className="space-y-6 animate-in fade-in text-left">
          <label className="text-[10px] font-bold text-slate-500 uppercase block mb-2 tracking-widest font-black">Select Image Source</label>
          <AssetPicker assets={assets} onSelect={(asset) => update({ imageUrl: asset.url })} />
       </div>
    );
  }

  if (localData.template === 'scorebug') {
    return <div className="grid grid-cols-2 gap-4 text-left"><InspectorInput label="Away Team" value={localData.awayName} onChange={e => update({awayName: e.target.value})} /><InspectorInput label="Home Team" value={localData.homeName} onChange={e => update({homeName: e.target.value})} /></div>;
  }
  return <div className="text-center text-slate-500 py-10 italic">Select a Template from the sidebar to begin.</div>;
};

