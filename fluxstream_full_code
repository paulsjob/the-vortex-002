        next.mlb.live_telemetry.pitch.speed = speed;
        pushLog(`pitch.type -> "${type}"`);
        pushLog(`pitch.speed -> "${speed}"`);

        const roll = Math.random();

        if (roll < 0.4) { 
           next.mlb.live_telemetry.count.balls++; 
           pushLog(`count.balls -> ${next.mlb.live_telemetry.count.balls}`);
           if (next.mlb.live_telemetry.count.balls > 3) { 
             next.mlb.live_telemetry.count.balls = 0; 
             next.mlb.live_telemetry.count.strikes = 0; 
             next.mlb.live_telemetry.bases.first = true; 
             pushLog('game.message -> "WALK"');
           }
        } 
        else if (roll < 0.7) { 
           next.mlb.live_telemetry.count.strikes++; 
           pushLog(`count.strikes -> ${next.mlb.live_telemetry.count.strikes}`);
           if (next.mlb.live_telemetry.count.strikes > 2) { 
             next.mlb.live_telemetry.count.balls = 0; 
             next.mlb.live_telemetry.count.strikes = 0; 
             next.mlb.live_telemetry.count.outs++; 
             pushLog('game.message -> "STRIKEOUT"');
